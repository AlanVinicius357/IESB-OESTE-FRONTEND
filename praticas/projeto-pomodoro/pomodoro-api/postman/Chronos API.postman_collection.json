{
  "info": {
    "_postman_id": "e5289c7f-22a0-4474-980d-6c27c529ece0",
    "name": "Chronos API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "47581509"
  },
  "item": [
    {
      "name": "2.1 Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2.2 Buscar Settings",
      "request": {
        "method": "GET",
        "header": []
      },
      "response": []
    },
    {
      "name": "2.3: Atualizar Settings",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"workTime\": 30,\r\n  \"shortBreakTime\": 10,\r\n  \"longBreakTime\": 20\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/settings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "settings"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2.4: Criar Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "pm.environment.set(\"taskId\", json.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"id\": \"{{$timestamp}}\",\r\n  \"name\": \"Task via Postman\",\r\n  \"duration\": 30,\r\n  \"type\": \"workTime\",\r\n  \"startDate\": {{$timestamp}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/tasks",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tasks"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2.5: Marcar Task",
      "request": {
        "method": "PATCH",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"completeDate\": {{$timestamp}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/{{taskId}}/complete",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tasks",
            "{{taskId}}",
            "complete"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2.6: Marcar Task como interrompida",
      "request": {
        "method": "PATCH",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"interruptDate\": {{$timestamp}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/{{taskId}}/interrupt",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tasks",
            "{{taskId}}",
            "interrupt"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2.7: Listar Tasks",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tasks"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2.8: Limpar Histórico",
      "request": {
        "method": "GET",
        "header": []
      },
      "response": []
    }
  ]
}